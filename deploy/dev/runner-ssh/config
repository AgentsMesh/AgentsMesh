# SSH Configuration for AgentsMesh Dev Runner

# Local Gitea Git server (Docker network)
Host gitea
    HostName gitea
    Port 22
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

# Example: External GitLab server (uses non-standard SSH port)
Host gitlab.example.com
    HostName gitlab.example.com
    Port 2222
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes
    StrictHostKeyChecking accept-new
