###############################################################################
# AgentsMesh — Bazel root module.
#
# Bzlmod-based. Each Phase of the Bazel migration adds its own deps here:
#   Phase 0: bazel_skylib + buildifier       ← you are here
#   Phase 1: rules_go + gazelle + go_deps    ← Go services
#   Phase 2: rules_rust + crate_universe     ← Rust Core crates
#   Phase 3: rules_rust_wasm_bindgen         ← Rust→WASM
#   Phase 4: aspect_rules_js + aspect_rules_ts + rules_nodejs  ← TS/pnpm
#   Phase 5: rules_swift + rules_apple (forked) + rules_swift_package_manager
#            + rules_xcodeproj                ← iOS
#   Phase 6: rules_oci + rules_pkg            ← OCI images + on-prem bundle
#
# See `.claude/plans/snuggly-spinning-dewdrop.md` for the full migration plan.
###############################################################################

module(
    name = "agentsmesh",
    version = "0.1.0",
    compatibility_level = 1,
)

bazel_dep(name = "bazel_skylib", version = "1.8.1")

bazel_dep(name = "buildifier_prebuilt", version = "7.3.1", dev_dependency = True)

bazel_dep(name = "platforms", version = "0.0.11")

###############################################################################
# Phase 1 — Go services
###############################################################################

bazel_dep(name = "rules_go", version = "0.59.0")
bazel_dep(name = "gazelle", version = "0.47.0")

# Pin the Go toolchain used for all module builds. Matches the `go X.Y` line
# in each go.mod. Bazel downloads and hermetically reuses this across CI +
# developer machines so nobody is building against their system Go.
go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(version = "1.25.0")

# Pull every transitive Go dependency from `go.work`. Gazelle walks the file
# and emits one `go_deps` import per module's `require` block.
go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")
go_deps.from_file(go_work = "//:go.work")
use_repo(go_deps, "com_github_alicebob_miniredis_v2", "com_github_anthropics_agentsmesh_agentfile", "com_github_anthropics_agentsmesh_proto", "com_github_aws_aws_sdk_go_v2", "com_github_aws_aws_sdk_go_v2_config", "com_github_aws_aws_sdk_go_v2_credentials", "com_github_aws_aws_sdk_go_v2_service_s3", "com_github_coreos_go_oidc_v3", "com_github_creack_pty", "com_github_creativeprojects_go_selfupdate", "com_github_crewjam_saml", "com_github_gin_contrib_cors", "com_github_gin_gonic_gin", "com_github_go_acme_lego_v4", "com_github_go_ldap_ldap_v3", "com_github_golang_jwt_jwt_v5", "com_github_google_uuid", "com_github_gorilla_websocket", "com_github_kardianos_service", "com_github_lib_pq", "com_github_masterminds_semver_v3", "com_github_mattn_go_runewidth", "com_github_maxmind_mmdbwriter", "com_github_ndolestudio_lemonsqueezy_go", "com_github_oschwald_maxminddb_golang", "com_github_pelletier_go_toml_v2", "com_github_pkg_browser", "com_github_redis_go_redis_extra_redisotel_v9", "com_github_redis_go_redis_v9", "com_github_resend_resend_go_v2", "com_github_robfig_cron_v3", "com_github_smartwalle_alipay_v3", "com_github_spf13_viper", "com_github_stretchr_testify", "com_github_stripe_stripe_go_v76", "com_github_thejerf_suture_v4", "com_github_uptrace_opentelemetry_go_extra_otelgorm", "com_github_userexistserror_conpty", "com_github_wechatpay_apiv3_wechatpay_go", "in_gopkg_yaml_v3", "io_gorm_driver_postgres", "io_gorm_driver_sqlite", "io_gorm_gorm", "io_gorm_plugin_dbresolver", "io_opentelemetry_go_contrib_instrumentation_github_com_gin_gonic_gin_otelgin", "io_opentelemetry_go_contrib_instrumentation_google_golang_org_grpc_otelgrpc", "io_opentelemetry_go_contrib_instrumentation_net_http_otelhttp", "io_opentelemetry_go_otel", "io_opentelemetry_go_otel_exporters_otlp_otlpmetric_otlpmetricgrpc", "io_opentelemetry_go_otel_exporters_otlp_otlptrace_otlptracegrpc", "io_opentelemetry_go_otel_exporters_stdout_stdoutmetric", "io_opentelemetry_go_otel_exporters_stdout_stdouttrace", "io_open