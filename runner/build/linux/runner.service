[Unit]
Description=AgentsMesh Runner - AI Agent Task Executor
Documentation=https://agentsmesh.ai/docs/runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agentsmesh
Group=agentsmesh
ExecStart=/usr/local/bin/runner run --config /etc/agentsmesh/config.yaml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true
ReadWritePaths=/var/lib/agentsmesh /var/log/agentsmesh

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agentsmesh-runner

[Install]
WantedBy=multi-user.target
